{
    "name": "@actlib/source",
    "version": "1.0.0",
    "license": "MIT",
    "private": true,
    "devDependencies": {
        "@commitlint/cli": "^19.7.1",
        "@commitlint/config-nx-scopes": "^19.7.1",
        "@eslint/js": "^9.21.0",
        "@nx/eslint": "20.4.6",
        "@nx/eslint-plugin": "20.4.6",
        "@nx/js": "20.4.6",
        "@swc-node/register": "^1.10.9",
        "@swc/core": "^1.11.5",
        "@swc/helpers": "^0.5.15",
        "@trivago/prettier-plugin-sort-imports": "^5.2.2",
        "@types/node": "22.13.9",
        "@typescript-eslint/parser": "^8.25.0",
        "eslint": "^9.21.0",
        "eslint-config-prettier": "^10.0.2",
        "eslint-import-resolver-typescript": "^3.8.3",
        "eslint-plugin-check-file": "^3.1.0",
        "eslint-plugin-import": "^2.31.0",
        "eslint-plugin-promise": "^7.2.1",
        "eslint-plugin-simple-import-sort": "^12.1.1",
        "husky": "^9.1.7",
        "lint-staged": "^15.4.3",
        "nx": "20.4.6",
        "prettier": "^3.5.2",
        "prettier-plugin-sort-json": "^4.1.1",
        "tslib": "^2.8.1",
        "typescript": "^5.8.2",
        "typescript-eslint": "^8.25.0"
    },
    "workspaces": [
        "packages/*"
    ],
    "packageManager": "yarn@4.7.0",
    "scripts": {
        "preinstall": "npx only-allow yarn",
        "upgrade-self": "yarn set version latest && yarn",
        "update-nx": "nx migrate latest && nx migrate --run-migrations --if-exists",
        "prettier": "prettier --write .",
        "lint:fix": "eslint . --fix",
        "prepare": "husky",
        "cmt": "npx cz",
        "lint:": "yarn nx affected -t lint",
        "build": "yarn nx affected -t build",
        "release": "yarn nx release --skip-publish",
        "publish": "yarn nx release publish"
    }
}
