{
    "name": "@actlib/source",
    "version": "1.0.0",
    "license": "MIT",
    "private": true,
    "devDependencies": {
        "@eslint/js": "^9.8.0",
        "@nx/eslint": "20.3.3",
        "@nx/eslint-plugin": "20.3.3",
        "@nx/js": "20.3.3",
        "@swc-node/register": "^1.10.9",
        "@swc/core": "^1.10.11",
        "@swc/helpers": "^0.5.15",
        "@trivago/prettier-plugin-sort-imports": "^5.2.1",
        "@types/node": "18.16.9",
        "@typescript-eslint/parser": "^8.21.0",
        "eslint": "^9.8.0",
        "eslint-config-prettier": "^9.0.0",
        "eslint-import-resolver-typescript": "^3.7.0",
        "eslint-plugin-check-file": "^2.8.0",
        "eslint-plugin-import": "^2.31.0",
        "eslint-plugin-promise": "^7.2.1",
        "eslint-plugin-simple-import-sort": "^12.1.1",
        "nx": "20.3.3",
        "prettier": "^3.4.2",
        "prettier-plugin-sort-json": "^4.1.1",
        "tslib": "^2.8.1",
        "typescript": "^5.7.3",
        "typescript-eslint": "^8.13.0"
    },
    "workspaces": [
        "packages/*"
    ],
    "packageManager": "yarn@4.6.0",
    "scripts": {
        "preinstall": "npx only-allow yarn",
        "upgrade-self": "yarn set version latest && yarn",
        "update-nx": "nx migrate latest && nx migrate --run-migrations --if-exists",
        "prettier": "prettier --write .",
        "lint:fix": "eslint . --fix",
        "prepare": "husky",
        "cmt": "npx cz",
        "lint:": "yarn nx affected -t lint",
        "build": "yarn nx affected -t build",
        "release": "yarn nx release --skip-publish",
        "publish": "yarn nx release publish"
    }
}
