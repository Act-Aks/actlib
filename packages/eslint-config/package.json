{
    "name": "@act-aks/eslint-config",
    "version": "0.0.1",
    "type": "commonjs",
    "main": "./src/index.js",
    "types": "./src/index.d.ts",
    "nx": {
        "sourceRoot": "packages/eslint-config/src",
        "projectType": "library",
        "name": "eslint-config",
        "release": {
            "version": {
                "generatorOptions": {
                    "packageRoot": "dist/packages/{projectName}",
                    "currentVersionResolver": "git-tag"
                }
            }
        },
        "targets": {
            "prettier": {
                "command": "prettier --write 'packages/{projectName}/**/*.{js,ts,json,md,yml,yaml}'"
            },
            "build": {
                "executor": "@nx/js:tsc",
                "outputs": [
                    "{options.outputPath}"
                ],
                "options": {
                    "outputPath": "dist/packages/eslint-config",
                    "main": "packages/eslint-config/src/index.ts",
                    "tsConfig": "packages/eslint-config/tsconfig.lib.json",
                    "assets": [
                        "packages/eslint-config/*.md"
                    ]
                }
            },
            "nx-release-publish": {
                "options": {
                    "packageRoot": "dist/packages/{projectName}",
                    "access": "public"
                },
                "dependsOn": [
                    "build"
                ]
            }
        }
    },
    "dependencies": {
        "@eslint/js": "^9.8.0",
        "@typescript-eslint/eslint-plugin": "8.21.0",
        "@typescript-eslint/parser": "^8.21.0",
        "eslint": "^9.8.0",
        "eslint-plugin-check-file": "^2.8.0",
        "eslint-plugin-import": "^2.31.0",
        "eslint-plugin-promise": "^7.2.1",
        "tslib": "^2.8.1"
    }
}
